# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=

# 토스페이먼츠
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Cloudflare R2 (영상/음원 호스팅 — S3 호환)
# 영상 자산 100~150개 ≤ free tier 10GB, 30분 만료 presigned URL로 발급
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=

# ── Plan 가드 토글 ─────────────────────────────────────────────
# middleware의 라우트 prefix별 plan 가드 활성화 여부.
# 운영: "true" (라이트 미만 사용자 차단), 베타: "false"로 우회 가능.
# (페이지 server component 가드는 ENV 토글과 무관하게 항상 작동)
PLAN_GATE_ENABLED=true

# 분석기·쓰레기통·행동연습장·명상의 일일 한도 검사 우회 토글.
# "true"면 모든 사용자가 무제한 (베타 검증 전용). 운영 환경에서는 미설정.
# AI_USAGE_LIMITS_DISABLED=true
